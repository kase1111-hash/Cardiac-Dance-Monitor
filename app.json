{
  "expo": {
    "name": "Cardiac Dance Monitor",
    "slug": "cardiac-dance-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cardiac-dance-monitor",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cardiacdance.monitor",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to detect your pulse via fingertip PPG",
        "NSBluetoothAlwaysUsageDescription": "Bluetooth is used to connect to your Innovo pulse oximeter"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#05050a"
      },
      "package": "com.cardiacdance.monitor",
      "permissions": []
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "composeCompilerVersion": "1.5.14",
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "minSdkVersion": 26
          }
        }
      ],
      "./plugins/withKotlinFix"
    ]
  }
}
